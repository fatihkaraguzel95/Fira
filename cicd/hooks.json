[
  {
    "id": "deploy-fira",
    "execute-command": "/home/sakgun/Fira/cicd/deploy.sh",
    "command-working-directory": "/home/sakgun/Fira",
    "response-message": "Deploy started.",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "REPLACE_WITH_YOUR_SECRET",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
